{
  "attribution": {
    "commit": ""
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-zig.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "greptile@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "frontend-design@claude-plugins-official": true,
    "fullstack-dev-skills@fullstack-dev-skills": true,
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "gitlab@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "semgrep@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": false,
    "firecrawl@claude-plugins-official": true,
    "circleback@claude-plugins-official": false,
    "claude-session-driver@superpowers-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "voltagent-subagents": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-claude-code-subagents"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if this session created or modified any files under a docs/ directory. If none were touched, return {\"decision\": \"approve\", \"reason\": \"No docs changed.\"}. If docs were touched, verify: (1) file is in the correct subdirectory per the docs convention in CLAUDE.md (plans, specs, adrs, research, benchmarks, notes), (2) filename follows YYYYMMDD_slug.md with lowercase hyphen-separated slug, (3) file has front-matter with title, status, and date, (4) docs/index.md has been updated with an entry for every new or renamed doc sorted by date descending, (5) superseded docs were moved to archive with status updated. If all rules pass, return {\"decision\": \"approve\", \"reason\": \"Docs convention verified.\"}. If any rule is violated, return {\"decision\": \"block\", \"reason\": \"<list each violation with file path and what needs fixing>\"}. You MUST respond with ONLY a JSON object, no other text."
          }
        ]
      }
    ]
  }
}
