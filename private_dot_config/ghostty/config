# --- Theme & Appearance ---
# Ghostty built-in themes usually use spaces or underscores. 
# Try 'catppuccin-mocha' without the hyphen if it fails, or use a basic one.
theme = cyberdream 

background-opacity = 0.9
background-blur-radius = 20

# --- Font ---
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-feature = -calt

# --- Window ---
maximize = true
# window-width = 160
# window-height = 48
window-padding-x = 2
window-padding-y = 2
confirm-close-surface = false
# If you use Zellij, set this to hidden to avoid UI conflict
# tab-style = hidden 

# --- Keybindings (Sanitized) ---
# Format: keybind = <mods>+<key>=<action>

# Splits
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+w=close_surface

# Navigation
keybind = ctrl+left=goto_split:left
keybind = ctrl+right=goto_split:right
keybind = ctrl+up=goto_split:top
keybind = ctrl+down=goto_split:bottom

# Tabs (Using literal names for brackets to avoid InvalidFormat)
keybind = alt+right_bracket=next_tab
keybind = alt+left_bracket=previous_tab

# Tab Movement
keybind = alt+shift+i=move_tab:-1
keybind = alt+shift+o=move_tab:1
